{
  "name": "@claude-nix-os/module-ui-railway-sidecar",
  "version": "1.0.0",
  "description": "ClaudeOS Module - Serves the ClaudeOS UI on a Railway public URL with proxy-aware routing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/", "claudeos-module.json"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/middleware dist/ && cp -r src/api dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-nix-os/module-ui-railway-sidecar.git"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "^15.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "vitest": "^3.2.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "next": "^15.3.2"
  }
}
